STEMSAI_ENVIRONMENT=development
STEMSAI_DEBUG=true
STEMSAI_STORAGE_ROOT=./storage
STEMSAI_MAX_UPLOAD_SIZE_MB=200
STEMSAI_REDIS_URL=redis://localhost:6379/0
STEMSAI_DEFAULT_ENGINE=htdemucs_6s
STEMSAI_DEVICE=cpu
STEMSAI_DEMUCS_MODEL_CACHE_DIR=./models_cache/demucs
STEMSAI_MDX_MODEL_CACHE_DIR=./models_cache/mdx
STEMSAI_CORS_ALLOW_ORIGINS=["http://localhost:3000"]
