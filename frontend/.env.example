# Usado no navegador do usuário para abrir a conexão WebSocket de progresso
# diretamente com o backend (precisa ser um host alcançável pelo browser).
NEXT_PUBLIC_WS_HOST=localhost:8000

# Usado apenas pelo servidor Next.js (rewrites de /api/*) — em dev local sem
# Docker, backend e frontend estão na mesma máquina, então localhost funciona.
# Em docker-compose isso é sobrescrito para "http://api:8000" (nome do serviço).
API_INTERNAL_URL=http://localhost:8000
